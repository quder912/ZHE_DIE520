<Window x:Class="ZD_code_xm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZD_code_xm"
        mc:Ignorable="d"
        Title="松下 A6 伺服上位机" Height="450" Width="800">
    <Grid>
        <!-- 定义两行布局：第一行放按钮（自动高度），第二行放列表框（填充剩余空间） -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 扫描串口按钮 -->
        <Button x:Name="btnScan" Content="扫描串口" Click="BtnScan_Click"
                Width="120" Height="30" Margin="10"/>

        <!-- 串口列表显示框 -->
        <ListBox x:Name="lstPorts" Grid.Row="1" Margin="10,0,10,10"/>
    </Grid>
</Window>
