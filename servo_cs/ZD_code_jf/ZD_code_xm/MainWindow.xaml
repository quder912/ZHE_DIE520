<!-- MainWindow.xaml
     松下 A6 伺服上位机 - 往复测试系统 UI 布局
     Step 1: UI 框架（所有按钮事件均为 stub，后续步骤填充） -->
<Window x:Class="ZD_code_xm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZD_code_xm"
        mc:Ignorable="d"
        Title="松下 A6 伺服上位机 - 往复测试系统" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- ====== 底部状态栏 ====== -->
        <StatusBar DockPanel.Dock="Bottom" Background="#F0F0F0">
            <StatusBarItem>
                <TextBlock>
                    <Run x:Name="runConnStatus" Text="● 未连接" Foreground="Gray"/>
                    <Run Text=" | "/>
                    <Run x:Name="runServoStatus" Text="● 伺服 OFF" Foreground="Gray"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="txtSbProgress" Text="进度: -- / --"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ====== 主体：左右两列 ====== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- 左列：控制面板，固定 340px -->
                <ColumnDefinition Width="340"/>
                <!-- 右列：日志区域，填满剩余空间 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ====== 左列：控制面板 ====== -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">

                    <!-- ── 串口配置 ── -->
                    <GroupBox Header="串口配置" Padding="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="55"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="36"/>
                            </Grid.RowDefinitions>

                            <!-- 串口选择 + 刷新按钮 -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="端口" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbPort" Grid.Row="0" Grid.Column="1" Margin="0,2" VerticalAlignment="Center"/>
                            <Button Grid.Row="0" Grid.Column="2" Content="刷新" Margin="4,2" Click="BtnRefreshPorts_Click"/>

                            <!-- 波特率（驱动器参数 Pr5.29=2 对应 9600） -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="波特率" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbBaud" Grid.Row="1" Grid.Column="1" Margin="0,2" VerticalAlignment="Center"
                                      SelectedIndex="3">
                                <ComboBoxItem Content="2400"/>
                                <ComboBoxItem Content="4800"/>
                                <ComboBoxItem Content="9600"/>
                                <ComboBoxItem Content="19200"/>
                                <ComboBoxItem Content="38400"/>
                            </ComboBox>

                            <!-- 数据位（Modbus RTU 固定 8 位） -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="数据位" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbDataBits" Grid.Row="2" Grid.Column="1" Margin="0,2" VerticalAlignment="Center"
                                      SelectedIndex="1">
                                <ComboBoxItem Content="7"/>
                                <ComboBoxItem Content="8"/>
                            </ComboBox>

                            <!-- 校验位（驱动器 Pr5.38=0 对应 8E1，偶校验） -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="校验位" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbParity" Grid.Row="3" Grid.Column="1" Margin="0,2" VerticalAlignment="Center"
                                      SelectedIndex="1">
                                <ComboBoxItem Content="无校验(None)"/>
                                <ComboBoxItem Content="偶校验(Even)"/>
                                <ComboBoxItem Content="奇校验(Odd)"/>
                            </ComboBox>

                            <!-- 停止位（Pr5.38=0 对应 1 停止位） -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="停止位" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbStopBits" Grid.Row="4" Grid.Column="1" Margin="0,2" VerticalAlignment="Center"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                            </ComboBox>

                            <!-- 连接 / 断开按钮 -->
                            <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="连接"
                                    x:Name="btnConnect" Click="BtnConnect_Click" Margin="0,4,4,0" Height="28"/>
                            <Button Grid.Row="5" Grid.Column="2" Content="断开"
                                    x:Name="btnDisconnect" Click="BtnDisconnect_Click" Margin="0,4,0,0" Height="28"
                                    IsEnabled="False"/>
                        </Grid>
                    </GroupBox>

                    <!-- ── 电机参数（速度/加减速档位，对应 Pr60.xx 寄存器） ── -->
                    <GroupBox Header="电机参数" Padding="6" Margin="0,6,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="目标速度" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtSpeed" Grid.Row="0" Grid.Column="1" Text="1000"
                                     Margin="0,2" VerticalAlignment="Center" HorizontalContentAlignment="Right"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="r/min" VerticalAlignment="Center" Margin="4,0,0,0"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="加速时间" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtAccel" Grid.Row="1" Grid.Column="1" Text="100"
                                     Margin="0,2" VerticalAlignment="Center" HorizontalContentAlignment="Right"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="ms" VerticalAlignment="Center" Margin="4,0,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="减速时间" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtDecel" Grid.Row="2" Grid.Column="1" Text="100"
                                     Margin="0,2" VerticalAlignment="Center" HorizontalContentAlignment="Right"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="ms" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </Grid>
                    </GroupBox>

                    <!-- ── 往复任务参数 ── -->
                    <GroupBox Header="往复任务" Padding="6" Margin="0,6,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="往复次数" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtCycleCount" Grid.Row="0" Grid.Column="1" Text="10000"
                                     Margin="0,2" VerticalAlignment="Center" HorizontalContentAlignment="Right"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="次" VerticalAlignment="Center" Margin="4,0,0,0"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="行程脉冲" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtStrokePulse" Grid.Row="1" Grid.Column="1" Text="8388608"
                                     Margin="0,2" VerticalAlignment="Center" HorizontalContentAlignment="Right"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="pulse" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </Grid>
                    </GroupBox>

                    <!-- ── 操作按钮 ── -->
                    <GroupBox Header="操作" Padding="6" Margin="0,6,0,0">

                        <StackPanel>
                            <!-- 伺服控制行 -->
                            <UniformGrid Columns="3" Margin="0,2">
                                <Button x:Name="btnServoOn" Content="伺服 ON" Click="BtnServoOn_Click"
                                        IsEnabled="False" Height="30" Margin="0,0,4,0"/>
                                <Button x:Name="btnServoOff" Content="伺服 OFF" Click="BtnServoOff_Click"
                                        IsEnabled="False" Height="30" Margin="0,0,4,0"/>
                                <Button x:Name="btnHome" Content="回零" Click="BtnHome_Click"
                                        IsEnabled="False" Height="30"/>
                            </UniformGrid>

                            <!-- 任务控制行 -->
                            <UniformGrid Columns="3" Margin="0,6">
                                <Button x:Name="btnStart" Content="▶ 开始" Click="BtnStart_Click"
                                        IsEnabled="False" Height="36" FontWeight="Bold"
                                        Background="#FF4CAF50" Foreground="White" Margin="0,0,4,0"/>
                                <Button x:Name="btnPause" Content="‖ 暂停" Click="BtnPause_Click"
                                        IsEnabled="False" Height="36" FontWeight="Bold"
                                        Background="#FFFFC107" Margin="0,0,4,0"/>
                                <Button x:Name="btnStop" Content="■ 停止" Click="BtnStop_Click"
                                        IsEnabled="False" Height="36" FontWeight="Bold"
                                        Background="#FFF44336" Foreground="White"/>
                            </UniformGrid>

                            <!-- 进度条 -->
                            <TextBlock Text="进度" Margin="0,4,0,2"/>
                            <ProgressBar x:Name="progressBar" Height="20" Minimum="0" Maximum="10000"/>

                            <!-- 进度文字 + 当前状态 -->
                            <TextBlock x:Name="txtProgress" Text="0 / 10000"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock x:Name="txtStatus" Text="状态: 空闲"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>

            <!-- 左右列分隔线 -->
            <GridSplitter Grid.Column="0" Width="3" HorizontalAlignment="Right"
                          VerticalAlignment="Stretch" Background="#CCCCCC"/>

            <!-- ====== 右列：运行日志 ====== -->
            <GroupBox Grid.Column="1" Header="运行日志" Margin="6,6,6,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="txtLog" Grid.Row="0" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Background="#FF1E1E1E" Foreground="#FFCCCCCC"/>

                    <Button Grid.Row="1" Content="清除日志" Click="BtnClearLog_Click"
                            Width="80" Height="24" Margin="0,4,0,0" HorizontalAlignment="Right"/>
                </Grid>
            </GroupBox>

        </Grid>

    </DockPanel>

</Window>
